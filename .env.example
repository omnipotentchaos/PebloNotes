# PebloNotes Environment Variables

# ── Backend Configuration ──
# Create a Supabase project at https://supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Used for signing session tokens
JWT_SECRET=change_this_to_a_random_secure_string

# Get a free Cerebras API key at https://cloud.cerebras.ai
CEREBRAS_API_KEY=your_cerebras_api_key
CEREBRAS_MODEL=llama3.1-8b

# Where your frontend is hosted (for CORS)
FRONTEND_URL=http://localhost:5173

# ── Frontend Configuration ──
# Same as FRONTEND_URL but configured for Vite
VITE_API_URL=http://localhost:8000
